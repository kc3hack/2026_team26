<Window x:Name="mainwindow" x:Class="desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:desktop"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="White"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal" Margin="8">
                <ComboBox x:Name="deviceCombo" Width="240" Margin="0,0,8,0" />
                <Button x:Name="connectButton" Content="Connect" Width="100" Click="ConnectButton_Click" />
                <ComboBox x:Name="audioCombo" Width="240" Margin="16,0,8,0" />
                <Button x:Name="audioConnectButton" Content="Connect Audio" Width="120" Click="AudioConnectButton_Click" />
            </StackPanel>
            <Image x:Name="imageDisplay" Stretch="Uniform" Height="350" Width="Auto" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10">
            <ProgressBar x:Name="volumeBar" Minimum="0" Maximum="1" Height="20" Width="200" RenderTransformOrigin="0.539,1.237"/>
            <TextBlock x:Name="audioScoreText" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="Bold">Voice: -</TextBlock>
        </StackPanel>
    </Grid>
</Window>

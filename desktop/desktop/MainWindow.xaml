<Window x:Class="desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:desktop"
        mc:Ignorable="d"
        Title="疲労度モニタリングシステム" Height="450" Width="800" Background="Transparent">

    <Grid Background="Black">
        <Image x:Name="imageDisplay" Stretch="Uniform" />
        <Image x:Name="videoDisplay" Stretch="UniformToFill" Opacity="1.0"/>

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="30">
            <TextBlock Text="疲労度 (3秒更新)" Foreground="LightGray" FontSize="18" HorizontalAlignment="Right"/>
            <TextBlock x:Name="txtScore" Text="100" Foreground="White" FontSize="80" FontWeight="Black"/>
        </StackPanel>

        <Border x:Name="warningOverlay" Background="#DDFF0000" Visibility="Hidden" VerticalAlignment="Top" Padding="20">
            <TextBlock Text="⚠️ 休息が必要です ⚠️" Foreground="White" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
